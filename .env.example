# ── FreeLLMAPI (recommended — uses paradocs local proxy) ─────────────────────
# Sync from paradocs install:
#   python -m hbac.scripts.sync_freellmapi --dir /path/to/paradocs/.freellmapi
HBAC_FREELLMAPI_DIR=/Users/vikranthnara/Documents/Github/paradocs/.freellmapi
HBAC_LLM_PROVIDER=freellmapi
HBAC_LLM_MODEL=auto
FREELLMAPI_BASE_URL=http://127.0.0.1:3001/v1
# FREELLMAPI_API_KEY=            # auto-read from SQLite when HBAC_FREELLMAPI_DIR is set

# ── Direct OpenAI (fallback) ──────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here

# Optional overrides
# ANTHROPIC_API_KEY=
# HBAC_LLM_BASE_URL=             # for vLLM / other OpenAI-compatible proxies
